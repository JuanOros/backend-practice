generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    

  status      TaskStatus @default(PENDING)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId      String?
  // @relation links this task to a user via userId foreign key. Make code easier becous set users info.
  // onDelete: SetNull — if the user is deleted, userId becomes NULL (tasks are preserved)
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ─── Treino Models ─────────────────────────────────────────────────────────

// Single user profile — nome is the primary key (used as upsert key)
model Perfil {
  nome            String   @id
  sexo            String
  altura_cm       Int
  idade           Int
  limitacoes      String[]
  suplementos     String[]
  meta_corrida_km Float
  updatedAt       DateTime @updatedAt
}

// Training program — singleton row, always overwritten
model Programa {
  id           String   @id @default("singleton")
  fase_atual   Int
  semana_atual Int
  inicio       String   // YYYY-MM-DD
  updatedAt    DateTime @updatedAt
}

// Body composition measurements — unique per date, ignored if date already exists
model Corpo {
  id                     String @id @default(cuid())
  data                   String @unique // YYYY-MM-DD
  peso_kg                Float
  gordura_pct            Float
  massa_gorda_kg         Float
  musculo_esqueletico_kg Float
  agua_corporal_kg       Float
}

// Workout sessions — unique per (data, tipo), ignored if pair already exists
model TreinoSessao {
  id                String @id @default(cuid())
  data              String // YYYY-MM-DD
  tipo              String
  descricao         String
  duracao_min       Int
  kcal              Float
  fc_media          Float
  fc_maxima         Float
  zona_predominante Int
  observacoes       String

  @@unique([data, tipo])
}
